{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/events/approve",          "destination": "/api/events/approve" },
    { "source": "/api/events/pending",          "destination": "/api/events/pending" },
    { "source": "/api/events/public",           "destination": "/api/events/public" },
    { "source": "/api/clubs",                   "destination": "/api/clubs/index" },
    { "source": "/api/clubs/members",           "destination": "/api/clubs/members" },
    { "source": "/api/:path*",                  "destination": "/api/index" },
    { "source": "/((?!api).*)",                 "destination": "/index.html" }
  ]
}
